OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1
GORK_API_KEY=sk-your-sub2-gork-api-key
GORK_BASE_URL=https://your-sub2-host/v1
GORK_TEXT_MODEL=grok-3-mini
GORK_IMAGE_MODEL=grok-2-image
DATABASE_URL=sqlite:///./aiweb.db
FRONTEND_ORIGIN=http://localhost:3000
RATE_LIMIT_PER_MINUTE=30
AUTH_SECRET_KEY=change-this-long-random-secret
AUTH_TOKEN_TTL_SECONDS=604800
ADMIN_SESSION_TTL_SECONDS=28800
ADMIN_COOKIE_SECURE=false
# In-process job worker (chat + image). Single-process deployments only.
JOB_WORKER_CONCURRENCY=2
JOB_TIMEOUT_SECONDS=300
JOB_POLL_INTERVAL_SECONDS=0.5
